{% liquid
  assign can_generate_saved_cart = false
  if customer and customer.tags contains 'cart-link-merchant'
    assign can_generate_saved_cart = true
  endif
%}

<script>
  window.ShareCartPro = window.ShareCartPro || {};
  window.ShareCartPro.canGenerate = {{ can_generate_saved_cart | json }};
  window.ShareCartPro.generateEndpoint = "{{ routes.root_url }}apps/saved-cart/generate/";
</script>
{{ 'share-cart-pro.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "SaveCart",
  "target": "body",
  "settings": []
}
{% endschema %}

